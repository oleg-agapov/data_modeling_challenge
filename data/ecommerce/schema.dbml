// E-commerce source data schema
// Generated from data/ecommerce/ CSV files

Project ecommerce {
  database_type: 'CSV / Data Warehouse'
  Note: 'Raw source tables for the e-commerce data modeling challenge'
}

Table users {
  id         text [pk, note: 'UUID – unique user identifier']
  firstName  text [note: 'User first name']
  lastName   text [note: 'User last name']
  email      text [note: 'User email address']
  created_on timestamp [note: 'Account creation timestamp']
  loc_id     text [ref: > locations.id, note: 'FK → locations.id (user default shipping location)']
}

Table products {
  id          text   [pk, note: 'UUID – unique product identifier']
  name        text   [note: 'Product display name']
  category    text   [note: 'Product category (Living Room, Bedroom, Kitchen)']
  description text      [note: 'Human-readable product description']
  price       decimal   [note: 'Catalog / base price']
  dimensions  text   [note: 'Free-text dimensions, e.g. "180 x 90 x 75"']
  material    text   [note: 'Main materials used']
  stock       integer   [note: 'Available inventory quantity at extraction time']
}

Table locations {
  id          text [pk, note: 'UUID – unique location identifier']
  code        text [note: 'Country code (observed: US)']
  fullName    text [note: 'Country full name']
  city        text [note: 'City name']
  address     text [note: 'Street address line']
  zip_code    text [note: 'Postal / ZIP code (stored as string to preserve leading zeros)']
  stateRegion text [note: 'State or region name']
}

Table orders {
  id             text   [pk, note: 'UUID – unique order identifier']
  user_id        text   [ref: > users.id, note: 'FK → users.id']
  date_ordered   timestamp [note: 'Order placement timestamp']
  status         text   [note: 'Order status (pending, shipped, delivered, cancelled)']
  payment_method text   [note: 'Payment channel (credit card, bank transfer, paypal)']
  updated        timestamp [note: 'Last record update timestamp']
}

Table order_items {
  id         text [pk, note: 'UUID – unique order line identifier']
  order_id   text [ref: > orders.id, note: 'FK → orders.id']
  product_id text [ref: > products.id, note: 'FK → products.id']
  quantity   integer [note: 'Quantity purchased for this line']
  unit_price decimal [note: 'Per-unit selling price captured at purchase time']
  discount   decimal [default: 0, note: 'Discount amount applied at line level']
  line_total decimal [note: 'Extended line amount (quantity * unit_price - discount)']
}

Table user_events {
  event_id           text   [pk, note: 'UUID – unique event identifier']
  user_id            text   [ref: > users.id, note: 'FK → users.id']
  event_type         text   [note: 'Event type (user_sign_up, page_view, add_to_cart)']
  event_timestamp    timestamp [note: 'Event occurrence timestamp']
  page_url           text   [note: 'URL / path where the event occurred']
  product_id         text   [null, ref: > products.id, note: 'FK → products.id; nullable, populated for product-related events only']
  additional_details text      [null, note: 'Extra event metadata; currently empty in all records']
}
